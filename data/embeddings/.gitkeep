# This directory holds index.json — the pre-computed vector index.
#
# Generated by: npm run ingest
# Format: JSON array of PolicyChunk objects (see types/index.ts)
#
# index.json is excluded from git by default (.gitignore).
# For CI/CD on Vercel, either:
#   a) Run the ingest script as a build step (add to package.json "build")
#   b) Commit a sanitized demo index for development/preview deployments
#
# Never commit index.json if it contains embeddings derived from
# confidential or PII-containing documents.
