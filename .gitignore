# Ingestion pipeline intermediate artifacts — regeneratable via npm run ingest:full.
# data/chunks/  — raw JSONL chunk files produced by the chunking step.
# NOT excluded:  data/index.json — the compiled embedding index MUST be committed
#                so that Vercel has it at runtime without a build-time ingest step.
#                Re-run `npm run ingest` locally and commit after policy changes.
data/chunks/
