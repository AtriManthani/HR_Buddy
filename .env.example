# ─────────────────────────────────────────────────────────────────────────────
# HR Policy Assistant — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# All variables are server-side only. None are prefixed with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────

# Your OpenAI secret API key. Required.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Chat completion model. Default: gpt-4o-mini
# Options: gpt-4o-mini | gpt-4o | gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# Embedding model. Default: text-embedding-3-small
# Options: text-embedding-3-small | text-embedding-3-large
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ─────────────────────────────────────────────────────────────

# Which vector store backend to use. Default: local
# "local"    — reads data/embeddings/index.json (no external service needed)
# "pinecone" — uses Pinecone API (requires PINECONE_API_KEY below)
VECTOR_STORE_PROVIDER=local

# Pinecone credentials — only required when VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=

# ── Session ──────────────────────────────────────────────────────────────────

# Secret used to sign session identifiers. Required. Min 32 characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-secure-random-string-of-at-least-32-chars

# Max conversation turns to retain per session. Default: 6
SESSION_MAX_TURNS=6

# ── RAG ──────────────────────────────────────────────────────────────────────

# Number of top-k policy chunks returned per query. Default: 5
RAG_TOP_K=5

# Minimum cosine similarity score for a chunk to qualify (0.0–1.0). Default: 0.75
RAG_MIN_SCORE=0.75

# ── Rate Limiting ────────────────────────────────────────────────────────────

# Max requests per IP per minute (sustained window). Default: 20
# Lower this for tighter production controls (e.g. 10).
RATE_LIMIT_MAX_PER_MINUTE=20

# Max requests per IP per 10 seconds (burst window). Default: 5
# Blocks rapid-fire spam. A human can't realistically exceed this naturally.
RATE_LIMIT_BURST_PER_10S=5

# Set to "true" to disable rate limiting entirely (automated tests only).
# Never set this in production.
RATE_LIMIT_DISABLED=

# ── Distributed Rate Limiting (optional upgrade) ──────────────────────────────
# To enforce limits globally across all Vercel edge nodes, configure Upstash
# Redis and swap InMemoryRateLimiter with UpstashRateLimiter in
# lib/rateLimit/rateLimiter.ts createRateLimiters().
#
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── App ──────────────────────────────────────────────────────────────────────

# Runtime environment. Set automatically by Vercel in production.
NODE_ENV=development
